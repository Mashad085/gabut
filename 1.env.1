# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=chatapp-super-secret-key-ganti-di-production-2024
JWT_EXPIRES_IN=86400

# Database (SQLite via sql.js — ganti ke MongoDB URI jika tersedia)
DB_TYPE=sqlite
SQLITE_PATH=./data/chatapp.db
# MONGODB_URI=mongodb://localhost:27017/chatapp

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
